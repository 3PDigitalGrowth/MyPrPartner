# ── Resend (form submissions + emails) ──────────────────────────────────────
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Sender address. Must be on a domain verified in Resend (https://resend.com/domains).
# Until myprpartner.com is verified, leave unset to fall back to Resend's shared
# onboarding sender (delivers only to the Resend account owner's email).
RESEND_FROM="My PR Partner <hello@myprpartner.com>"

# Comma-separated internal recipients for form-submission notifications.
ADMIN_NOTIFICATION_EMAILS=info@myprpartner.com,alex@3pdigital.com.au

# Absolute site URL used for links inside emails.
NEXT_PUBLIC_SITE_URL=https://myprpartner.com
